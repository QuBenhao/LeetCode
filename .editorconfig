# EditorConfig - https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 120

[*.go]
indent_style = tab
indent_size = 4

[*.java]
indent_size = 4

[*.ts]
indent_size = 2

[*.js]
indent_size = 2

[*.json]
indent_size = 2

[*.rs]
indent_size = 4

[*.cpp]
indent_size = 4

[*.hpp]
indent_size = 4

[*.h]
indent_size = 4

[*.c]
indent_size = 4

[BUILD]
indent_size = 4

[*.bazel]
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2
